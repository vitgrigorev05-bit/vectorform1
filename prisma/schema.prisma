// Упрощённая схема для локальной разработки без базы данных
// Для работы с mock-данными см. lib/mock-data.ts

generator client {
  provider = "prisma-client-js"
}

// База данных отключена для локальной разработки
// Раскомментируйте для работы с реальной базой:
// datasource db {
//   provider = "postgresql"
//   url      = env("DATABASE_URL")
// }

enum UserRole {
  GUEST
  CUSTOMER
  AUTHOR
  PARTNER
  ADMIN
}

enum OrderStatus {
  DRAFT
  CALCULATING
  PENDING_PAYMENT
  PAID
  ASSIGNED_TO_PARTNER
  PRINTING
  POST_PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUND_DISPUTE
}

enum MaterialType {
  PLA
  ABS
  PETG
  TPU
  NYLON
  RESIN
  METAL
  CERAMIC
}

enum PrintQuality {
  DRAFT
  STANDARD
  HIGH
  ULTRA
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  role          UserRole  @default(CUSTOMER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relationships
  authoredModels   Model3D[]
  orders           Order[]
  partnerProfile   Partner?
  authorProfile    Author?
  reviews          Review[]
  favorites        Favorite[]
  cartItems        CartItem[]
  transactions     Transaction[]
  shippingAddresses ShippingAddress[]
}

model Author {
  id          String   @id @default(cuid())
  userId      String   @unique
  bio         String?
  website     String?
  socialLinks Json?
  rating      Float    @default(0.0)
  totalEarnings Decimal @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  user        User      @relation(fields: [userId], references: [id])
  models      Model3D[]
  royalties   Royalty[]
}

model Partner {
  id              String   @id @default(cuid())
  userId          String   @unique
  companyName     String
  description     String?
  address         String
  city            String
  country         String
  postalCode      String
  rating          Float    @default(0.0)
  isActive        Boolean  @default(true)
  maxPrintVolume  Float    // cm³
  availableMaterials Json   // Array of MaterialType
  equipment       Equipment[]
  pricingRules    Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relationships
  user            User      @relation(fields: [userId], references: [id])
  assignedOrders  OrderAssignment[]
  completedOrders Order[]
}

model Equipment {
  id          String   @id @default(cuid())
  partnerId   String
  name        String
  type        String   // FDM, SLA, SLS, etc.
  buildVolume Json     // {x, y, z} in mm
  materials   Json     // Array of MaterialType
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  partner     Partner  @relation(fields: [partnerId], references: [id])
}

model Model3D {
  id              String   @id @default(cuid())
  title           String
  description     String
  shortDescription String?
  categoryId      String
  authorId        String
  price           Decimal?
  isFree          Boolean  @default(false)
  licenseType     String   @default("Standard")
  fileFormat      String
  fileSize        Float    // MB
  dimensions      Json     // {width, height, depth} in mm
  volume          Float    // cm³
  thumbnailUrl    String?
  previewImages   String[] // Array of image URLs
  tags            String[]
  downloadCount   Int      @default(0)
  printCount      Int      @default(0)
  rating          Float    @default(0.0)
  isPublished     Boolean  @default(true)
  isFeatured      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relationships
  category    ModelCategory @relation(fields: [categoryId], references: [id])
  author      Author        @relation(fields: [authorId], references: [id])
  files       ModelFile[]
  reviews     Review[]
  favorites   Favorite[]
  orders      Order[]
  similarModels SimilarModel[]
}

model ModelCategory {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  description String?
  icon        String?
  parentId    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  // Relationships
  parent      ModelCategory? @relation("CategoryToCategory", fields: [parentId], references: [id])
  children    ModelCategory[] @relation("CategoryToCategory")
  models      Model3D[]
}

model ModelFile {
  id          String   @id @default(cuid())
  modelId     String
  fileName    String
  fileUrl     String
  fileType    String   // STL, OBJ, 3MF, etc.
  fileSize    Float    // MB
  version     String   @default("1.0")
  isPrimary   Boolean  @default(true)
  uploadedAt  DateTime @default(now())

  model       Model3D  @relation(fields: [modelId], references: [id])
}

model SimilarModel {
  id          String   @id @default(cuid())
  modelId     String
  similarToId String

  model       Model3D  @relation("SimilarFrom", fields: [modelId], references: [id])
  similarTo   Model3D  @relation("SimilarTo", fields: [similarToId], references: [id])

  @@unique([modelId, similarToId])
}

model Order {
  id              String       @id @default(cuid())
  orderNumber     String       @unique
  customerId      String
  modelId         String?
  uploadedFileUrl String?
  status          OrderStatus  @default(DRAFT)
  material        MaterialType
  color           String?
  quality         PrintQuality @default(STANDARD)
  dimensions      Json         // Custom dimensions if scaled
  quantity        Int          @default(1)
  totalAmount     Decimal
  taxAmount       Decimal      @default(0)
  shippingAmount  Decimal      @default(0)
  discountAmount  Decimal      @default(0)
  finalAmount     Decimal
  currency        String       @default("USD")
  shippingAddress Json
  billingAddress  Json?
  customerNotes   String?
  estimatedPrintTime  Int?     // hours
  estimatedDelivery   DateTime?
  printedByPartnerId  String?
  assignedAt      DateTime?
  startedPrinting DateTime?
  finishedPrinting DateTime?
  shippedAt       DateTime?
  deliveredAt     DateTime?
  cancelledAt     DateTime?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relationships
  customer        User        @relation(fields: [customerId], references: [id])
  model           Model3D?    @relation(fields: [modelId], references: [id])
  printedBy       Partner?    @relation(fields: [printedByPartnerId], references: [id])
  calculation     PrintCalculation?
  assignments     OrderAssignment[]
  transactions    Transaction[]
}

model PrintCalculation {
  id              String   @id @default(cuid())
  orderId         String   @unique
  modelVolume     Float    // cm³
  materialPrice   Decimal  // per cm³
  printTime       Int      // hours
  printCost       Decimal  // per hour
  supportCost     Decimal
  postProcessing  Decimal
  complexityMultiplier Float @default(1.0)
  platformFee     Decimal
  partnerMargin   Decimal
  shippingCost    Decimal
  subtotal        Decimal
  total           Decimal
  currency        String   @default("USD")
  calculationDate DateTime @default(now())
  isValid         Boolean  @default(true)

  order           Order    @relation(fields: [orderId], references: [id])
}

model OrderAssignment {
  id          String   @id @default(cuid())
  orderId     String
  partnerId   String
  status      String   @default("PENDING") // PENDING, ACCEPTED, REJECTED
  proposedPrice Decimal
  partnerNotes String?
  assignedAt   DateTime @default(now())
  respondedAt  DateTime?
  responseNotes String?

  order       Order   @relation(fields: [orderId], references: [id])
  partner     Partner @relation(fields: [partnerId], references: [id])

  @@unique([orderId, partnerId])
}

model Transaction {
  id          String   @id @default(cuid())
  orderId     String?
  userId      String
  type        String   // PAYMENT, ROYALTY, PAYOUT, REFUND
  amount      Decimal
  currency    String   @default("USD")
  status      String   @default("PENDING") // PENDING, COMPLETED, FAILED
  paymentMethod String?
  transactionId String? // External payment ID
  metadata    Json?
  createdAt   DateTime @default(now())
  processedAt DateTime?

  order       Order?   @relation(fields: [orderId], references: [id])
  user        User     @relation(fields: [userId], references: [id])
}

model Royalty {
  id          String   @id @default(cuid())
  authorId    String
  modelId     String
  orderId     String?
  amount      Decimal
  percentage  Float    // Royalty percentage
  status      String   @default("PENDING") // PENDING, PAID
  paidAt      DateTime?
  createdAt   DateTime @default(now())

  author      Author   @relation(fields: [authorId], references: [id])
  model       Model3D  @relation(fields: [modelId], references: [id])
  order       Order?   @relation(fields: [orderId], references: [id])
}

model Review {
  id          String   @id @default(cuid())
  userId      String
  modelId     String?
  orderId     String?
  rating      Int      // 1-5
  comment     String?
  isVerified  Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
  model       Model3D? @relation(fields: [modelId], references: [id])
  order       Order?   @relation(fields: [orderId], references: [id])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  modelId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id])
  model     Model3D  @relation(fields: [modelId], references: [id])

  @@unique([userId, modelId])
}

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  modelId   String
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id])
  model     Model3D  @relation(fields: [modelId], references: [id])

  @@unique([userId, modelId])
}

model ShippingAddress {
  id          String   @id @default(cuid())
  userId      String
  fullName    String
  addressLine1 String
  addressLine2 String?
  city        String
  state       String?
  postalCode  String
  country     String
  phone       String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id])
}

model PricingCoefficient {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  value       Decimal
  minValue    Decimal?
  maxValue    Decimal?
  isActive    Boolean  @default(true)
  appliesTo   String?  // MATERIAL, PRINT_TIME, COMPLEXITY, etc.
  materialType MaterialType?
  region      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model PlatformConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}
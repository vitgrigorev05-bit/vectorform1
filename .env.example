# ВекторФорм — переменные окружения
# Скопируйте этот файл в `.env.local` для разработки и в Vercel Environment Variables для прода.

# ---------------------------------------------------------------------------
# База данных — Neon Postgres
# ---------------------------------------------------------------------------
# 1. Создайте проект на https://neon.tech (бесплатный тариф)
# 2. Скопируйте connection string из Dashboard → "Connect" → Pooled connection
# 3. Для миграций нужна "direct" версия URL — без `-pooler` в хосте.
#    Пример: pooled  ep-xxx-pooler.region.aws.neon.tech
#            direct  ep-xxx.region.aws.neon.tech
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# ---------------------------------------------------------------------------
# NextAuth
# ---------------------------------------------------------------------------
# Сгенерировать секрет: `openssl rand -base64 32`
NEXTAUTH_SECRET="REPLACE_ME_WITH_RANDOM_32_BYTES"
# В проде — https://your-domain.vercel.app
NEXTAUTH_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# ЮKassa (платежи) — заполнить, когда получите доступ к личному кабинету
# https://yookassa.ru/developers/api
# ---------------------------------------------------------------------------
YOOKASSA_SHOP_ID=""
YOOKASSA_SECRET_KEY=""

# ---------------------------------------------------------------------------
# Хранилище файлов (опционально) — S3-совместимое для прода
# Без этих переменных файлы сохраняются в public/uploads (только локально)
# ---------------------------------------------------------------------------
S3_ENDPOINT=""
S3_REGION=""
S3_BUCKET=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
